---
// A single ranked product card for review pages (4-zone: media | body | side).
export interface Product {
  rank: number;
  name: string;
  brand?: string;
  image?: string; // /images/... in public. Omit → tasteful placeholder box.
  score: number; // out of 10 (real: derived from verified ratings / disclosed assessment — see how-we-rate)
  scoreLabel?: string; // Outstanding / Excellent / Very Good / Good / Decent
  starRating?: number; // out of 5, real average (retailer-listed products)
  reviewCount?: number; // real count (retailer-listed products)
  trustNote?: string; // shown instead of a review count for direct-sold offers (no retailer aggregate)
  badge?: string; // "Best Overall" | "Best Value" | "Editor's Choice"
  price?: string; // current price — ONLY direct-sold offers (Amazon ToS forbids static Amazon prices)
  oldPrice?: string; // strikethrough anchor price (direct-sold only)
  discount?: string; // e.g. "30% Off" — only if genuinely running
  url: string; // affiliate link (hero) or Amazon link (backfill) — includes subid
  ctaLabel?: string;
  awardBadge?: string; // /images/... our own editorial badge (top pick only)
  awardNote?: string; // short, substantiated line under the badge
  pros: string[];
  cons?: string[];
  blurb?: string;
}
// `repeat` = this is the duplicated "best option" block; omit the id so the
// anchor target stays unique and the top-picks jump links keep working.
const { product, repeat } = Astro.props as { product: Product; repeat?: boolean };
const p = product;
const stars = p.starRating
  ? "★".repeat(Math.round(p.starRating)) + "☆".repeat(5 - Math.round(p.starRating))
  : null;
---

<div class:list={["card", "rank-card", { "is-top": p.rank === 1 }]} id={repeat ? undefined : `rank-${p.rank}`}>
  <div class="rank-media">
    {
      p.image ? (
        <img class="rank-img" src={p.image} alt={p.name} loading="lazy" width="150" height="150" />
      ) : (
        <div class="rank-ph" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 8 12 3 3 8v8l9 5 9-5V8Z" />
            <path d="m3 8 9 5 9-5" />
            <path d="M12 13v8" />
          </svg>
        </div>
      )
    }
    {p.rank === 1 ? <span class="rank-flag top">#1 Best</span> : <span class="rank-flag num">#{p.rank}</span>}
  </div>

  <div class="rank-body">
    {/* Only the #1 pick carries a label — keeps all attention on the top pick. */}
    {p.badge && p.rank === 1 && <span class="badge badge-choice">{p.badge}</span>}
    <div class="product-title">{p.name}</div>
    {p.price && (
      <p class="rank-price">
        <span class="now">{p.price}</span>
        {p.oldPrice && <span class="was">{p.oldPrice}</span>}
      </p>
    )}
    <div class="proscons">
      <ul class="pros">{p.pros.map((pro) => <li>{pro}</li>)}</ul>
      {p.cons && p.cons.length > 0 && (
        <ul class="cons">{p.cons.map((con) => <li>{con}</li>)}</ul>
      )}
    </div>
    {p.blurb && <p style="font-size:0.92rem;color:var(--muted);margin:12px 0 0;">{p.blurb}</p>}
  </div>

  <div class="rank-side">
    {p.scoreLabel && <div class="score-label">{p.scoreLabel}</div>}
    <div class="score-pill">
      <span class="num">{p.score.toFixed(1)}</span>
      <span class="label">out of 10</span>
    </div>
    {stars && <div class="stars">{stars}</div>}
    {
      p.reviewCount ? (
        <div class="rank-trust">{p.reviewCount.toLocaleString()} verified reviews</div>
      ) : p.trustNote ? (
        <div class="rank-trust">{p.trustNote}</div>
      ) : null
    }
    <a href={p.url} class="btn btn-block" rel="sponsored nofollow noopener" target="_blank">
      {p.ctaLabel ?? "View Site"}
    </a>
    {p.discount && <div class="rank-offer">{p.discount}</div>}
    {p.awardBadge && (
      <img class="award-badge" src={p.awardBadge} alt="The Life Insider top pick" loading="lazy" width="78" height="78" />
    )}
    {p.awardNote && <div class="rank-trust">{p.awardNote}</div>}
  </div>
</div>
