---
import Base from "../layouts/Base.astro";
---

<Base
  title="The Life Insider — Smarter Buying, Backed by Real Reviews"
  description="We analyze thousands of verified customer reviews, compare specs, and track prices to rank the best products — so you can buy with confidence."
>
  <!-- Hero -->
  <section class="section" style="padding-bottom:40px;">
    <div class="container">
      <div class="hero-grid">
        <div>
          <div class="kicker">Independent Product Reviews</div>
          <h1>Find the best product in minutes — not hours.</h1>
          <p class="lede" style="margin-bottom:26px;">
            We analyze thousands of verified customer reviews, compare
            specifications, and track real prices to rank the top products in
            each category. No guesswork. No hype.
          </p>
          <a href="/reviews/" class="btn">Browse Our Top Picks</a>
        </div>

        <!-- Ranked-pick preview card -->
        <div class="card" style="padding:20px;border:2px solid var(--accent);">
          <span class="badge badge-choice">Best Overall</span>
          <div style="font-size:1.02rem;font-weight:700;color:var(--ink);margin:12px 0 14px;line-height:1.35;">
            Pocket Hose Copper Bullet
          </div>
          <div style="display:flex;align-items:center;gap:16px;">
            <div class="score-pill">
              <span class="num">9.1</span>
              <span class="label">Outstanding</span>
            </div>
            <div>
              <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
              <div class="review-count">2,400 verified reviews</div>
            </div>
          </div>
          <a
            href="/reviews/best-expandable-garden-hoses/"
            class="btn btn-block"
            style="margin-top:16px;"
          >
            See the Review
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section
    class="section-soft"
    style="padding:22px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);"
  >
    <div class="container">
      <div class="trust-strip">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="m8.5 12 2.4 2.4 4.6-5"></path>
          </svg>
          <span>Built on verified reviews</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
            <path d="M14 3v5h5"></path>
            <path d="M9 13h6M9 17h5"></path>
          </svg>
          <span>Methodology published</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3.5 11.3V4.5a1 1 0 0 1 1-1h6.8a2 2 0 0 1 1.4.6l6.7 6.7a2 2 0 0 1 0 2.8l-6.4 6.4a2 2 0 0 1-2.8 0l-6.7-6.7a2 2 0 0 1-.6-1.4Z"></path>
            <circle cx="7.7" cy="7.7" r="1.3"></circle>
          </svg>
          <span>Real prices tracked</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v18"></path>
            <path d="M7 6h10"></path>
            <path d="M5.5 21h13"></path>
            <path d="M7 6 4 12a3 3 0 0 0 6 0Z"></path>
            <path d="M17 6l3 6a3 3 0 0 1-6 0Z"></path>
          </svg>
          <span>Independent &amp; honest</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container">
      <h2 style="text-align:center;">How The Life Insider works</h2>
      <div class="steps">
        <div class="step card">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4v16h16"></path>
              <rect x="7" y="12" width="3" height="5" rx="0.6"></rect>
              <rect x="12" y="8" width="3" height="9" rx="0.6"></rect>
              <rect x="17" y="14" width="3" height="3" rx="0.6"></rect>
            </svg>
          </div>
          <h3>1. We gather the data</h3>
          <p>
            For every category, we collect verified customer ratings, review
            volumes, specifications, pricing history, and warranty and returns
            policies across the leading products.
          </p>
        </div>
        <div class="step card">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8.5" r="5.5"></circle>
              <path d="M8.8 13 7 21l5-2.8L17 21l-1.8-8"></path>
            </svg>
          </div>
          <h3>2. We score every product</h3>
          <p>
            Each product receives an Insider Score out of 10 — built from real
            verified-buyer ratings, weighted by review volume, value for money,
            and brand reliability. <a href="/how-we-rate/">See our full methodology.</a>
          </p>
        </div>
        <div class="step card">
          <div class="step-icon is-accent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3 5 6v5c0 4.5 3 7.6 7 9 4-1.4 7-4.5 7-9V6z"></path>
              <path d="m9 12 2 2 4-4.5"></path>
            </svg>
          </div>
          <h3>3. You buy with confidence</h3>
          <p>
            We rank the results, flag the best overall pick and the best value,
            and link you straight to the retailer's current price. The research
            is done — the decision is yours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by category -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2 style="text-align:center;">Browse by category</h2>
      <p style="text-align:center;color:var(--muted);max-width:520px;margin:0 auto;">
        Honest, data-backed rankings across the things you actually buy — with
        new categories added regularly.
      </p>
      <div class="cat-grid">
        <a href="/reviews/" class="cat-tile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 21v-8"></path>
            <path d="M12 13c0-3.2-2.2-5.2-5.2-5.2-.7 0-1.4.1-1.4.1-.4 3.2 1.8 5.2 5 5.2Z"></path>
            <path d="M12 11.5c0-3.2 2.2-5.2 5.2-5.2.7 0 1.4.1 1.4.1.4 3.2-1.8 5.2-5 5.2Z"></path>
          </svg>
          <div class="cat-name">Garden &amp; Outdoor</div>
          <div class="cat-sub">Live now</div>
        </a>
        <div class="cat-tile is-soon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 11 12 4l8 7"></path>
            <path d="M6 10v9h12v-9"></path>
            <path d="M10 19v-5h4v5"></path>
          </svg>
          <div class="cat-name">Home &amp; Kitchen</div>
          <div class="cat-sub">Coming soon</div>
        </div>
        <div class="cat-tile is-soon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.4A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z"></path>
            <path d="M7.5 12h2l1-2 2 4 1-2h2.5"></path>
          </svg>
          <div class="cat-name">Health &amp; Wellness</div>
          <div class="cat-sub">Coming soon</div>
        </div>
        <div class="cat-tile is-soon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="12" rx="2"></rect>
            <path d="M8 20h8"></path>
            <path d="M12 16v4"></path>
          </svg>
          <div class="cat-name">Tech &amp; Gadgets</div>
          <div class="cat-sub">Coming soon</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why trust our rankings -->
  <section class="section section-soft">
    <div class="container-narrow" style="text-align:center;">
      <div class="score-pill" style="margin:0 auto 16px;">
        <span class="num">9.4</span>
        <span class="label">Insider Score</span>
      </div>
      <h2>Why trust our rankings?</h2>
      <p>
        Because they're built on evidence, not opinion. Our scores start with
        what thousands of verified buyers actually experienced — not what a
        brand's marketing department says. We disclose exactly how we make
        money and how products are ranked, in plain English.
      </p>
      <p>
        <a href="/how-we-rate/">Read our rating methodology →</a><br />
        <a href="/advertising-disclosure/">Read our advertising disclosure →</a>
      </p>
    </div>
  </section>
</Base>
