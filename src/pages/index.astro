---
import Base from "../layouts/Base.astro";
---

<Base
  title="The Life Insider — Smarter Buying, Backed by Real Reviews"
  description="We analyze thousands of verified customer reviews, compare specs, and track prices to rank the best products — so you can buy with confidence."
>
  <section class="hero">
    <div class="container">
      <div class="kicker">Independent Product Reviews</div>
      <h1>Find the best product in minutes — not hours.</h1>
      <p class="lede">
        We analyze thousands of verified customer reviews, compare
        specifications, and track real prices to rank the top products in each
        category. No guesswork. No hype.
      </p>
      <a href="/reviews/" class="btn">Browse Our Top Picks</a>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <h2 style="text-align:center;">How The Life Insider works</h2>
      <div class="steps">
        <div class="step card">
          <div class="n">1</div>
          <h3>We gather the data</h3>
          <p>
            For every category, we collect verified customer ratings, review
            volumes, specifications, pricing history, and warranty and returns
            policies across the leading products.
          </p>
        </div>
        <div class="step card">
          <div class="n">2</div>
          <h3>We score every product</h3>
          <p>
            Each product receives an Insider Score out of 10 — built from real
            verified-buyer ratings, weighted by review volume, value for money,
            and brand reliability. <a href="/how-we-rate/">See our full methodology.</a>
          </p>
        </div>
        <div class="step card">
          <div class="n">3</div>
          <h3>You buy with confidence</h3>
          <p>
            We rank the results, flag the best overall pick and the best value,
            and link you straight to the retailer's current price. The research
            is done — the decision is yours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow" style="text-align:center;">
      <h2>Why trust our rankings?</h2>
      <p>
        Because they're built on evidence, not opinion. Our scores start with
        what thousands of verified buyers actually experienced — not what a
        brand's marketing department says. We disclose exactly how we make
        money and how products are ranked, in plain English.
      </p>
      <p>
        <a href="/how-we-rate/">Read our rating methodology →</a><br />
        <a href="/advertising-disclosure/">Read our advertising disclosure →</a>
      </p>
    </div>
  </section>
</Base>
