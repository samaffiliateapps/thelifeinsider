---
import Base from "../layouts/Base.astro";

// As blog posts are published, add them here (newest first).
const posts: { title: string; href: string; blurb: string; date: string }[] = [
  {
    title: "How to Spot a Fake Product Review",
    href: "/blog/how-to-spot-fake-reviews/",
    blurb:
      "Nine reliable tells that separate a genuine customer review from a planted one — and a faster way to read any review section.",
    date: "July 2026",
  },
  {
    title: "What a Star Rating Doesn't Tell You",
    href: "/blog/star-ratings-review-volume/",
    blurb:
      "A 4.8 with 40 reviews is not better than a 4.6 with 12,000. How to read ratings using volume, distribution, and recency.",
    date: "July 2026",
  },
  {
    title: "How to Tell If a Discount Is Actually a Deal",
    href: "/blog/is-that-discount-really-a-deal/",
    blurb:
      "'50% off' is often theater. How to check whether a sale price is genuine using price history, anchor pricing, and timing.",
    date: "July 2026",
  },
  {
    title: "Why Expandable Garden Hoses Kink, Leak, and Burst",
    href: "/blog/why-expandable-hoses-kink/",
    blurb:
      "How expandable hoses actually work, why cheap ones fail in a season, and how to make a good one last for years.",
    date: "July 2026",
  },
  {
    title: "How to Choose a Garden Hose That Lasts",
    href: "/blog/garden-hose-buying-guide/",
    blurb:
      "Length, diameter, material, connectors, and safety — the five specs that decide whether a hose lasts a decade or a summer.",
    date: "July 2026",
  },
];
---

<Base
  title="Blog — Smart Shopping, Explained | The Life Insider"
  description="Practical guides on how to research products, spot fake reviews, time your purchases, and shop smarter."
>
  <section class="section">
    <div class="container">
      <div class="kicker">The Insider Blog</div>
      <h1>Smart shopping, explained</h1>
      <p class="lede" style="max-width: 640px;">
        Practical, no-hype guides on researching products, spotting fake
        reviews, and getting the most for your money.
      </p>

      {
        posts.length === 0 ? (
          <div class="card" style="padding: 36px; margin-top: 28px; text-align: center;">
            <h3>First articles publishing soon.</h3>
            <p style="margin-bottom: 0;">
              Our first guides are being finalized. In the meantime, see
              <a href="/how-we-rate/">how our product ratings work</a>.
            </p>
          </div>
        ) : (
          <div style="margin-top: 28px;">
            {posts.map((p) => (
              <a href={p.href} class="card" style="display:block; padding: 22px 26px; margin-bottom: 14px;">
                <h3 style="margin-bottom: 4px;">{p.title}</h3>
                <p style="margin-bottom: 4px;">{p.blurb}</p>
                <span class="review-count">{p.date}</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Base>
