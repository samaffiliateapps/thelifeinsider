---
import Base from "./Base.astro";
import ProductCard from "../components/ProductCard.astro";
import EmailCapture from "../components/EmailCapture.astro";
import type { Product } from "../components/ProductCard.astro";

export interface Props {
  title: string;
  description: string;
  h1: string;
  updated: string;
  intro: string[]; // paragraphs
  products: Product[];
  deepDive?: { heading: string; body: string[] }; // deep-dive on #1 pick
  faqs?: { q: string; a: string }[];
  highlights?: { title: string; text: string }[]; // 3 key strengths of the #1 pick
}

const { title, description, h1, updated, intro, products, deepDive, faqs, highlights } =
  Astro.props;
const top = products.find((p) => p.rank === 1);
---

<Base title={title} description={description}>
  <article>
    <!-- Header -->
    <section class="section" style="padding-bottom:24px;">
      <div class="container">
        <div class="kicker">Buying Guide</div>
        <h1>{h1}</h1>
        <p class="updated">Last updated: {updated}</p>
        <div class="prose" style="max-width:820px;">
          {intro.map((para) => <p set:html={para} />)}
        </div>
      </div>
    </section>

    <!-- Quick picks summary -->
    <section style="padding:0 0 8px;">
      <div class="container">
        <div class="card" style="padding:20px 24px;background:var(--bg-soft);">
          <strong style="color:var(--ink);">Our Top Picks:</strong>
          <div style="display:flex;flex-wrap:wrap;gap:8px 20px;margin-top:10px;">
            {products.map((p) => (
              <a href={`#rank-${p.rank}`} style="font-size:0.95rem;">
                <strong>#{p.rank}</strong> {p.badge ? `${p.badge}: ` : ""}{p.brand ?? p.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Ranked list -->
    <section class="section" style="padding-top:28px;">
      <div class="container">
        {products.map((p) => <ProductCard product={p} />)}
      </div>
    </section>

    <!-- Best option on the market: repeat the #1 pick + its key strengths -->
    {top && (
      <section class="section" style="padding-top:0;">
        <div class="container">
          <div class="best-band">The Best Option on the Market</div>
          <ProductCard product={top} repeat />
          {highlights && highlights.length > 0 && (
            <div class="highlights">
              {highlights.map((h, i) => (
                <div class="highlight">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {i === 0 && (
                      <>
                        <path d="M9 3v6M15 3v6" />
                        <path d="M6 9h12v3a6 6 0 0 1-12 0z" />
                        <path d="M12 18v3" />
                      </>
                    )}
                    {i === 1 && (
                      <>
                        <path d="M5 8h9a4 4 0 0 1 0 8H8" />
                        <path d="m10 13-2 3 2 3" />
                        <circle cx="18" cy="6" r="2" />
                      </>
                    )}
                    {i === 2 && <path d="M13 2 4 14h7l-1 8 9-12h-7z" />}
                  </svg>
                  <div>
                    <div class="h-title">{h.title}</div>
                    <div class="h-text">{h.text}</div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Deep dive on #1 -->
    {deepDive && top && (
      <section class="section section-soft">
        <div class="container-narrow prose">
          <div class="kicker">Our #1 Pick</div>
          <h2>{deepDive.heading}</h2>
          {deepDive.body.map((para) => <p set:html={para} />)}
          <div style="text-align:center;margin-top:24px;">
            <a href={top.url} class="btn" rel="sponsored nofollow noopener" target="_blank">
              {top.ctaLabel ?? "Check Price"}
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- How we rate strip -->
    <section class="section">
      <div class="container-narrow" style="text-align:center;">
        <h2>How We Rated These Products</h2>
        <p>
          Every Insider Score is built from four weighted inputs: verified
          customer ratings (50%), review volume and consistency (20%), value for
          money (15%), and brand reliability (15%). We don't fabricate test
          results or invent ratings. <a href="/how-we-rate/">Read our full methodology →</a>
        </p>
      </div>
    </section>

    <!-- Email capture -->
    <EmailCapture />

    <!-- FAQ -->
    {faqs && faqs.length > 0 && (
      <section class="section">
        <div class="container-narrow prose">
          <h2>Frequently Asked Questions</h2>
          {faqs.map((f) => (
            <>
              <h3>{f.q}</h3>
              <p set:html={f.a} />
            </>
          ))}
        </div>
      </section>
    )}

    <section class="section" style="padding-top:0;">
      <div class="container-narrow">
        <p class="disclosure-line" style="text-align:center;margin:0;">
          Reader-supported: we may earn a commission when you buy through our
          links, at no extra cost to you — it never affects our{" "}
          <a href="/how-we-rate/">verified-data scores</a>. See our{" "}
          <a href="/advertising-disclosure/">Advertising Disclosure</a>.
        </p>
      </div>
    </section>
  </article>
</Base>
